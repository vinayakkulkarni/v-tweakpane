  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vinayakkulkarni/v-tweakpane.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
