    "build": "vp pack",
    "test": "echo 'test!'",
    "prepare": "is-ci || husky"
  },
  "dependencies": {
    "@tweakpane/plugin-essentials": "^0.2.1",
    "tweakpane": "^4.0.5"
  },
  "devDependencies": {
    "@commitlint/cli": "latest",
    "@commitlint/config-conventional": "latest",
    "@tsdown/css": "^0.22.0",
    "@tweakpane/core": "^2.0.5",
    "@types/node": "^25.8.0",
    "@types/uuid": "^11.0.0",
    "@vue/runtime-dom": "^3.5.34",
    "husky": "latest",
    "is-ci": "latest",
    "lint-staged": "latest",
    "sass": "^1.99.0",
    "typescript": "^6.0.3",
    "unplugin-vue": "^7.2.0",
    "uuid": "^14.0.0",
    "vite-plus": "^0.1.21",
    "vue": "^3.5.34",
    "vue-tsc": "^3.2.9"
  },
  "peerDependencies": {
    "@tweakpane/plugin-essentials": "^0.2.1",
    "tweakpane": "^4.0.4",
    "vue": "^3.4.7"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.1.2",
      "onFail": "warn"
    },
    "runtime": {
      "name": "node",
      "version": ">=24"
    }
  },
  "packageManager": "pnpm@11.1.2+sha512.415a1cc25974731e75455c1468371be74c5aa5fb7621b50d4056d222451609f11412f23fd602e6169f1e060466641f798597e1be961a10688836a67b16569499"
