{
  "name": "v-tweakpane",
  "version": "0.3.3",
  "private": false,
  "description": "Tweakpane for Vue",
  "keywords": [
    "Vue tweakpane",
    "tweakpane",
    "v-tweakpane",
    "vue-tweakpane.js"
  ],
  "homepage": "https://github.com/vinayakkulkarni/v-tweakpane#readme",
