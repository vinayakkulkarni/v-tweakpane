    "@types/node": "^25.9.0",
    "husky": "^9.1.7",
    "is-ci": "^4.1.0",
    "lint-staged": "^17.0.5",
    "sass": "^1.99.0",
    "typescript": "^6.0.3",
    "unplugin-vue": "^7.2.0",
    "vite-plus": "^0.1.21",
    "vue": "^3.5.34",
    "vue-tsc": "^3.3.0"
  },
